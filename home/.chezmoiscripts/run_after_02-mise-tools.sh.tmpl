#!/usr/bin/env bash
set -euo pipefail

echo "--- Installing mise-managed tools ---"
if command -v mise >/dev/null 2>&1; then
  mise_bin="mise"
elif [ -x "$HOME/.local/bin/mise" ]; then
  mise_bin="$HOME/.local/bin/mise"
elif [ -x /opt/homebrew/bin/mise ]; then
  mise_bin="/opt/homebrew/bin/mise"
elif [ -x /usr/local/bin/mise ]; then
  mise_bin="/usr/local/bin/mise"
elif [ -x /home/linuxbrew/.linuxbrew/bin/mise ]; then
  mise_bin="/home/linuxbrew/.linuxbrew/bin/mise"
else
  echo "mise is not installed yet; skipping mise-managed tools"
  exit 0
fi

mise_config="${XDG_CONFIG_HOME:-$HOME/.config}/mise/config.toml"
if [ ! -r "$mise_config" ]; then
  echo "mise config not found at $mise_config; skipping mise-managed tools"
  exit 0
fi

MISE_CONFIG_FILE="$mise_config" "$mise_bin" install -y
