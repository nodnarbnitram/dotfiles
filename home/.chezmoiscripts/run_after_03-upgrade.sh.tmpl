#!/usr/bin/env bash
set -euo pipefail

find_homebrew() {
  if command -v brew >/dev/null 2>&1; then
    command -v brew
  elif [ -x /opt/homebrew/bin/brew ]; then
    printf '%s\n' /opt/homebrew/bin/brew
  elif [ -x /usr/local/bin/brew ]; then
    printf '%s\n' /usr/local/bin/brew
  elif [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    printf '%s\n' /home/linuxbrew/.linuxbrew/bin/brew
  else
    return 1
  fi
}

find_mise() {
  if command -v mise >/dev/null 2>&1; then
    command -v mise
  elif [ -x "$HOME/.local/bin/mise" ]; then
    printf '%s\n' "$HOME/.local/bin/mise"
  elif [ -x /opt/homebrew/bin/mise ]; then
    printf '%s\n' /opt/homebrew/bin/mise
  elif [ -x /usr/local/bin/mise ]; then
    printf '%s\n' /usr/local/bin/mise
  elif [ -x /home/linuxbrew/.linuxbrew/bin/mise ]; then
    printf '%s\n' /home/linuxbrew/.linuxbrew/bin/mise
  else
    return 1
  fi
}

if [ "${DOTFILES_SKIP_UPGRADE:-}" = 1 ]; then
  echo "--- Skipping upgrades (DOTFILES_SKIP_UPGRADE=1) ---"
  exit 0
fi

if [ "${DOTFILES_UPGRADE:-}" != 1 ]; then
  if [ ! -t 0 ]; then
    echo "--- Skipping upgrades (non-interactive; set DOTFILES_UPGRADE=1 to run) ---"
    exit 0
  fi

  read -r -p "Upgrade system packages and managed tools now? [y/N] " answer
  case "$answer" in
    y|Y|yes|YES) ;;
    *)
      echo "--- Skipping upgrades ---"
      exit 0
      ;;
  esac
fi

echo "--- Upgrading OS packages ---"
if command -v pacman >/dev/null 2>&1; then
  sudo pacman -Syu --noconfirm
elif command -v apt-get >/dev/null 2>&1; then
  sudo apt-get update
  sudo apt-get upgrade -y
elif brew_bin="$(find_homebrew)"; then
  eval "$("$brew_bin" shellenv)"
  "$brew_bin" update
  "$brew_bin" upgrade
else
  echo "No supported package manager found; skipping OS package upgrades."
fi

echo "--- Upgrading mise-managed tools ---"
if mise_bin="$(find_mise)"; then
  "$mise_bin" self-update -y || true
  "$mise_bin" upgrade -y || "$mise_bin" upgrade
else
  echo "mise not found; skipping mise upgrades."
fi

echo "--- Updating zimfw modules ---"
if [ -x "${XDG_DATA_HOME:-$HOME/.local/share}/zimfw/zimfw.zsh" ]; then
  zsh "${XDG_DATA_HOME:-$HOME/.local/share}/zimfw/zimfw.zsh" update || true
else
  echo "zimfw not installed; skipping zimfw update."
fi

echo "--- Updating tmux plugins ---"
if [ -x "$HOME/.tmux/plugins/tpm/bin/update_plugins" ] && [ -n "${TMUX:-}" ]; then
  "$HOME/.tmux/plugins/tpm/bin/update_plugins" all || true
else
  echo "TPM not available or not in a tmux session; skipping tmux plugin update."
fi

echo "--- Upgrade completed ---"
