{{- if ne .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail

{{ $desktop := false -}}
{{ if hasKey . "desktop" }}{{ $desktop = .desktop }}{{ end -}}
{{ $work := false -}}
{{ if hasKey . "work" }}{{ $work = .work }}{{ end }}

echo "--- Installing OS packages ---"
if command -v pacman >/dev/null 2>&1; then
  packages=(
{{- range .packages.arch.common }}
    {{ . | quote }}
{{- end }}
{{- if $desktop }}
{{- range .packages.arch.desktop }}
    {{ . | quote }}
{{- end }}
{{- end }}
{{- if $work }}
{{- range .packages.arch.work }}
    {{ . | quote }}
{{- end }}
{{- end }}
  )
  sudo pacman -Syu --needed --noconfirm "${packages[@]}"
elif command -v apt-get >/dev/null 2>&1; then
  sudo apt-get update
  packages=(
{{- range .packages.apt.common }}
    {{ . | quote }}
{{- end }}
{{- if $desktop }}
{{- range .packages.apt.desktop }}
    {{ . | quote }}
{{- end }}
{{- end }}
{{- if $work }}
{{- range .packages.apt.work }}
    {{ . | quote }}
{{- end }}
{{- end }}
  )
  sudo apt-get install -y "${packages[@]}" || true
else
  echo "Unsupported package manager; install packages manually."
fi
{{- end -}}
