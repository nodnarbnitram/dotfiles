{{- $gitEditor := .editor -}}
{{- if hasKey . "waitEditor" }}{{- $gitEditor = .waitEditor -}}{{- end }}
[core]
	editor = {{ $gitEditor | quote }}
[alias]
	st = status
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[include]
	path = ~/.config/git/local.inc
