# >>> wsw github packages token >>>
# Let npm/pi install private @weshipwork packages from GitHub Packages.
# .npmrc reads this via ${GITHUB_PACKAGES_TOKEN}; the token itself is not stored there.
if [[ -z "${GITHUB_PACKAGES_TOKEN:-}" ]] && command -v gh >/dev/null 2>&1; then
  export GITHUB_PACKAGES_TOKEN="$(gh auth token 2>/dev/null || true)"
fi
