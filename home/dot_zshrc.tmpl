# Coding-agent launch helpers: agent sessions get Zenity-backed sudo prompts.
_agent_with_zenity_sudo() {
  AI_AGENT_SUDO_ASKPASS=1 \
  SUDO_ASKPASS="$HOME/.local/bin/zenity-sudo-askpass" \
  command "$@"
}

opencode() {
  _agent_with_zenity_sudo opencode "$@"
}

claude() {
  _agent_with_zenity_sudo claude "$@"
}

pi() {
  _agent_with_zenity_sudo pi "$@"
}

agent-shell() {
  AI_AGENT_SUDO_ASKPASS=1 \
  SUDO_ASKPASS="$HOME/.local/bin/zenity-sudo-askpass" \
  "${SHELL:-/usr/bin/zsh}" -l "$@"
}


tm() {
  # If no argument is provided, just list sessions
  if [[ -z "$1" ]]; then
    tmux list-sessions
    return
  fi

  # Check if session exists; attach if it does, create if it doesn't
  tmux has-session -t "$1" 2>/dev/null
  if [ $? -eq 0 ]; then
    tmux attach -t "$1"
  else
    tmux new-session -s "$1"
  fi
}

oc() {
  local port
  port=$(shuf -i 49152-65535 -n 1)
  OPENCODE_PORT="$port" \
  opencode --port "$port" "$@"
}

oct() {
  local port session_name cmd
  port=$(shuf -i 49152-65535 -n 1)
  session_name="opencode-${port}"

  printf -v cmd "%q " "OPENCODE_PORT=$port" opencode --port "$port" "$@"
  tmux new-session -A -s "$session_name" "$cmd"
}
