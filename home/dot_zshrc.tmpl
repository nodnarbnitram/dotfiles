# Managed by chezmoi. Keep this entrypoint portable and safe to share.
# Most shell behavior lives under ${XDG_CONFIG_HOME:-$HOME/.config}/zsh/.

export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

export ZIM_CONFIG_FILE="$XDG_CONFIG_HOME/zsh/zimrc"
export ZIM_HOME="$XDG_DATA_HOME/zimfw"

[ -r "$XDG_CONFIG_HOME/zsh/helpers.zsh" ] && source "$XDG_CONFIG_HOME/zsh/helpers.zsh"

# Prompt defaults must be set before zimfw sources Pure. Pure is activated by
# zimfw's module init, not by zsh's promptinit helper.
[ -r "$XDG_CONFIG_HOME/zsh/helpers/prompt.zsh" ] && source "$XDG_CONFIG_HOME/zsh/helpers/prompt.zsh"

if [ -r "$ZIM_HOME/init.zsh" ]; then
  source "$ZIM_HOME/init.zsh"
fi

# Bun's generated completion calls compinit if it is sourced too early. Load it
# after zimfw's completion module so it only registers its compdef.
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"

# Private or machine-specific shell config belongs here. Do not manage this
# file in the shareable base; let a private overlay or local setup provide it.
[ -r "$XDG_CONFIG_HOME/zsh/private.zsh" ] && source "$XDG_CONFIG_HOME/zsh/private.zsh"
